{
  "name": "functions",
  "description": "Cloud Functions for Firebase — Kurukh Dictionary",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf lib",
    "lint": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "cors": "^2.8.5",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/node": "^22.5.0",
    "firebase-functions-test": "^3.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  },
  "private": true
}
